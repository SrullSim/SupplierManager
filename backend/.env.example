# ── App ────────────────────────────────────────────────────────────────────────
APP_ENV=staging                       # staging | prod
SECRET_KEY=change-me-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Database ───────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=bakery_orders

# ── Factory config ─────────────────────────────────────────────────────────────
FACTORY_TIMEZONE=Asia/Jerusalem       # IANA timezone name

# ── Bootstrap (prod one-off) ───────────────────────────────────────────────────
# Set these only when running scripts/bootstrap_admin.py in prod.
# Unset / leave empty at all other times.
BOOTSTRAP_ADMIN_CODE=
BOOTSTRAP_ADMIN_PASSWORD=

# ── Notifications ──────────────────────────────────────────────────────────────
FIREBASE_CREDENTIALS_JSON=            # path to Firebase service-account JSON
