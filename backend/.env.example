# ── App ────────────────────────────────────────────────────────────────────────
APP_ENV=staging                       # staging | prod
SECRET_KEY=change-me-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Database ───────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=bakery_orders

# ── Factory config ─────────────────────────────────────────────────────────────
FACTORY_TIMEZONE=Asia/Jerusalem       # IANA timezone name

# ── Bootstrap (prod one-off) ───────────────────────────────────────────────────
# Set these only when running scripts/bootstrap_admin.py in prod.
# Unset / leave empty at all other times.
BOOTSTRAP_ADMIN_CODE=
BOOTSTRAP_ADMIN_PASSWORD=

# ── Notifications ──────────────────────────────────────────────────────────────
# Path to a Firebase service-account JSON. When empty, push is a logged no-op
# (everything else works; real device push just isn't dispatched).
FIREBASE_CREDENTIALS_JSON=

# ── Scheduler & reminders ──────────────────────────────────────────────────────
SCHEDULER_ENABLED=true                 # runs lock-finalization + reminders in the background
SCHEDULER_INTERVAL_MINUTES=5           # how often the background job runs
REMINDER_LEAD_HOURS=2                  # send the "order closes soon" reminder this long before cutoff
